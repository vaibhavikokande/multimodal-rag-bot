# App
APP_NAME=Multimodal Enterprise RAG Bot
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ragbot
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/ragbot

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (Required)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic (Optional - for Claude models)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Vector Database
VECTOR_DB_PROVIDER=chromadb
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=enterprise_rag

# Pinecone (if using Pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=enterprise-rag

# File Storage
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=500

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ragbot-uploads

# Admin
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123456

# Monitoring
SENTRY_DSN=
ENABLE_PROMETHEUS=true

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]
